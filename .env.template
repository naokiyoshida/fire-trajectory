# --- Google Sheets ---
# Sheets URL から取得: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Google Cloud Console で発行したサービスアカウントの JSON 鍵ファイルへのパス
# このファイルを Sheets の編集権限で共有しておくこと
GOOGLE_SERVICE_ACCOUNT_JSON=config/google-service-account.json

# --- Money Forward URLs ---
# 注意: ログイン時は必ず「メールアドレスでログイン」を選ぶこと。
# Google/Yahoo OAuth は Playwright が自動化ブラウザとして検出され
# ブロックされるため使用不可。マネフォ側の設定で
# 「メールアドレス + パスワード」によるログインを有効化しておくこと。
MF_LOGIN_URL=https://moneyforward.com/sign_in
MF_TRANSACTIONS_URL=https://moneyforward.com/cf
MF_ASSETS_URL=https://moneyforward.com/bs/portfolio

# --- Scraping behavior ---
STORAGE_STATE_PATH=data/storage-state.json
SNAPSHOTS_DIR=data/snapshots
SYNC_MONTHS=6

# Full Sync (--full) で過去に遡って取得を始める年月。Database が空のときにも自動で
# 使われる。形式: YYYY/MM
FULL_SYNC_START=2021/10

# 資産スナップショットから除外する金融機関（カンマ区切り）
# 住信SBIネット銀行はハブ口座のため、二重カウント回避目的で意図的に除外
EXCLUDED_INSTITUTIONS=住信SBIネット銀行

# --- Notification (optional, Gmail SMTP) ---
# 失敗時のメール通知を有効にするには、Gmail で以下を準備:
#   1. アカウントに 2段階認証を有効化
#   2. Google アカウント設定 → セキュリティ → 「アプリパスワード」を発行
#   3. 発行された16文字のパスワードを GMAIL_APP_PASSWORD に設定
# 未設定の場合は ConsoleNotifier にフォールバック（ログにのみ出力）
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=
